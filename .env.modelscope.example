# ModelScope 创空间 环境变量参考
#
# 在魔搭创空间「设置 → 环境变量」中逐项配置下列变量(不要提交真实密钥到仓库)。
# 部署方式:SDK 选择 Docker,平台会用仓库根目录的 Dockerfile 构建,容器监听 7860。

# 必填:外部 PostgreSQL 连接串
DATABASE_URL=postgres://user:password@host:5432/gradcheck?sslmode=require

# 必填:JWT 签名密钥(至少 24 个字符)
JWT_SECRET=replace-with-a-long-random-secret-string

# 必填:高德天气 Key
AMAP_WEATHER_KEY=your-amap-weather-key

# 可选:DeepSeek API Key(启用 AI 选课/培养方案解析时需要)
DEEPSEEK_API_KEY=your-deepseek-api-key

# 可选:跨域来源。单端口同源部署可留空或设为创空间访问域名
# CORS_ORIGIN=https://your-space-url

# 以下变量已有合理默认值,容器内由 Dockerfile 预设,一般无需手动配置:
# HOST=0.0.0.0
# PORT=7860
